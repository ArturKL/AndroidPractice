<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".screen.details.DetailsFragment">

    <TextView
        android:id="@+id/details_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_margin="8dp"
        style="@style/TextAppearance.AppCompat.Title"

        app:layout_constraintTop_toTopOf="parent"
        tools:text="Sample Title"/>

    <ImageView
        android:id="@+id/details_iv"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="8dp"

        app:layout_constraintStart_toStartOf="@id/details_title"
        app:layout_constraintEnd_toEndOf="@id/details_title"
        app:layout_constraintTop_toBottomOf="@id/details_title"
        tools:background="@color/purple_200"/>

    <TextView
        android:id="@+id/details_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        style="@style/TextAppearance.AppCompat.Body1"

        app:layout_constraintStart_toStartOf="@id/details_iv"
        app:layout_constraintEnd_toEndOf="@id/details_iv"
        app:layout_constraintTop_toBottomOf="@id/details_iv"
        tools:text="Sample Description"/>

</androidx.constraintlayout.widget.ConstraintLayout>